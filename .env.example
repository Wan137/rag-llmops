# Copy this file: cp .env.example .env
# Do not commit .env - it's in .gitignore.

# --- Google Gemini (free tier - get a key at https://aistudio.google.com/apikey) ---
GOOGLE_API_KEY=

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# --- RAG Config ---
RAG_LLM_MODEL=gemini-2.5-flash
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- ChromaDB ---
RAG_CHROMA_PERSIST_DIR=./data/chroma_db
RAG_COLLECTION_NAME=documents

# --- Chunking ---
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# --- Retrieval ---
RAG_RETRIEVAL_K=4
RAG_SCORE_THRESHOLD=0.3

# --- MLflow ---
MLFLOW_TRACKING_URI=./mlruns
